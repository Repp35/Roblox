-- ================== AUTO PARRY LOOP ==================
local function bind(ch)
    setupCharacter(ch)

    local hrp     = ch:WaitForChild("HumanoidRootPart", 10)
    local running = true

    local lastBallPos = nil
    local ballResetAt = 0
    local vel         = Vector3.zero
    local lastBP      = nil
    local lastBT      = nil
    local pingTimer   = 0

    task.spawn(function()
        while running do
            local dt  = task.wait(0.016)
            local now = tick()

            if not (ch and ch.Parent and hrp and hrp.Parent) then continue end

            -- Ping update
            pingTimer = pingTimer + dt
            if pingTimer >= 2 then
                pingTimer = 0
                task.spawn(updatePing)
            end

            -- Clash decay
            if ClashState.Active and (now - ClashState.LastActivationTime) > Config.clashDecayTime then
                stopClash()
            end

            -- Fallback reset do parryDone
            if parryDone and (now - lastProcessReset) >= Config.processResetInt then
                parryDone = false
            end

            if spamOn then continue end
            if not getgenv().__deltaV7_autoParryOn then continue end

            -- Snapshot do syncData
            local data      = getSyncData()
            local ballModel = getBallModel()

            if not (ballModel and ballModel.Parent) then continue end

            -- Locked = bola parada, pula
            if BallSync.Locked then continue end

            -- Teleporte = pula esse frame
            if BallSync.Teleported then continue end

            -- Posição real (sempre RealPosition do syncData, não modelo visual)
            local bp = (BallSync.RealPosition ~= Vector3.new())
                       and BallSync.RealPosition
                       or  ballModel.Position

            -- Detecta teleporte/reset pela posição
            if lastBallPos then
                local jump = (bp - lastBallPos).Magnitude
                if jump > Config.ballResetThresh then
                    parryDone        = false
                    preArmed         = false
                    lastProcessReset = now
                    ballResetAt      = now
                    vel              = Vector3.zero
                    lastBP, lastBT   = nil, nil
                    lastBallPos      = bp
                    continue
                end
            end
            lastBallPos = bp

            if (now - ballResetAt) < Config.ballResetLockout then continue end

            -- Clash detection
            local currentTarget = BallSync.TargetID
            if currentTarget and currentTarget > 0 then
                updateClashDetection(currentTarget, bp, hrp)
            end

            -- Velocidade
            local spd = (BallSync.Speed and BallSync.Speed > 0) and BallSync.Speed or nil

            if spd then
                if lastBP and lastBT then
                    local dtt = now - lastBT
                    if dtt > 0 then
                        local dir = (bp - lastBP)
                        if dir.Magnitude > 0.001 then
                            vel = dir.Unit * spd
                        end
                    end
                end
                lastBT, lastBP = now, bp
            elseif not lastBT then
                lastBT, lastBP = now, bp
            else
                local dtt = now - lastBT
                if dtt > 0 then
                    local raw = (bp - lastBP) / dtt
                    local a   = dt / (Config.velSmooth + dt)
                    vel       = vel + (raw - vel) * a
                    lastBT, lastBP = now, bp
                end
            end

            local speed  = spd or vel.Magnitude
            local hrpPos = hrp.Position
            local d      = (bp - hrpPos).Magnitude
            local app    = vel.Magnitude > 0.1 and vel:Dot(hrpPos - bp) > 0
            local tgt    = isTargetMe()
            local ping   = getPingCompensation()

            -- ============================================================
            -- PRIORIDADE 1: GRACE MODE — parry imediato
            -- Grace = bola vai direto, sem curva, mais perigoso
            -- ============================================================
            if BallSync.Grace and tgt and not parryDone then
                sendParry()
                parryDone        = true
                lastProcessReset = now
                setState("normal")
                continue
            end

            -- ============================================================
            -- PRIORIDADE 2: clientHitTarget — alarme de morte iminente
            -- O jogo já acha que vai te matar, último recurso
            -- ============================================================
            if BallRep and BallRep.clientHitTarget and tgt and not parryDone then
                sendParry()
                parryDone        = true
                lastProcessReset = now
                setState("normal")
                continue
            end

            -- ============================================================
            -- PRIORIDADE 3: Distância com compensação real
            -- Usa aceleração da bola pra prever velocidade no impacto
            -- ============================================================
            local tImp = speed > 1 and (d / speed) or 1000000

            -- Velocidade prevista no momento do impacto (considerando aceleração)
            local predictedSpeed = math.min(speed + SPEED_OVER_TIME * tImp, MAX_SPEED)

            -- Distância de ativação:
            -- KillDist + margem de ping (baseada na velocidade prevista) + margem fixa
            local activationDist = KILL_DIST
                + (predictedSpeed * ping)
                + Config.safetyMargin

            -- Grace bonus: se Grace ativo, margem extra
            if data and data.Grace then
                activationDist = activationDist + Config.graceExtraMargin
            end

            local can = tgt and app and speed > 5
                and d <= activationDist
                and tImp <= (Config.maxImpactTime + ping)

            if can and not parryDone then
                sendParry()
                parryDone        = true
                lastProcessReset = now
                setState("normal")
            end
        end
    end)

    ch.AncestryChanged:Connect(function(_, p)
        if not p then
            running   = false
            parryDone = false
            preArmed  = false
            setSpam(false)
            stopClash()
            ballWasMine       = false
            lastBallPos       = nil
            updateGUI()
        end
    end)

    getgenv().__na_aex_conn = { Disconnect = function() running = false end }
end

