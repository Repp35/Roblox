-- ================== isTargetMe — SEM grace frames ==================
-- Grace frames causavam double parry. Agora é direto.
local function isTargetMe()
    local data = getSyncData()
    if data then
        if data.TargetPlayerID == lp.UserId then return true end
        if data.HighlightTargetPlayerID == lp.UserId then return true end
    end
    -- fallback legado
    local ch = lp.Character
    if ch and ch:FindFirstChild("Highlight") then return true end
    if WS:GetAttribute("GameBallTarget") == lp.UserId then return true end
    return false
end

-- ================== BALL SYNC ==================
local BallSync = {
    Speed              = 0,
    TargetID           = -999,
    RealPosition       = Vector3.new(),
    Grace              = false,
    Locked             = false,
    Teleported         = false,
    DeflectDirInterp   = 1,
    HighlightTargetID  = -999,
}

local lastDeflectInterp = 1

RS.Heartbeat:Connect(function()
    local data = getSyncData()
    if not data then return end

    local newTarget     = data.TargetPlayerID           or -999
    local newHighlight  = data.HighlightTargetPlayerID  or -999
    local newSpeed      = data.Speed                    or 0
    local newPos        = data.RealPosition             or Vector3.new()
    local newGrace      = data.Grace                    or false
    local newLocked     = data.Locked                   or false
    local newTeleported = data.Teleported               or false
    local newDeflectDI  = data.DeflectDirectionInterp   or 1

    -- Detecta deflect (alguém acabou de parrar)
    -- DeflectDirectionInterp vai de <1 pra 1 após parry
    if newDeflectDI < 0.95 and lastDeflectInterp >= 0.95 then
        -- bola acabou de ser deflectida, libera parryDone
        parryDone = false
        preArmed  = false
    end
    lastDeflectInterp = newDeflectDI

    -- Teleporte: reseta tudo
    if newTeleported then
        parryDone = false
        preArmed  = false
    end

    -- Troca de alvo
    if newTarget ~= BallSync.TargetID then
        if BallSync.TargetID == lp.UserId then
            -- bola saiu de mim
            ballWasMine = true
            parryDone   = false
        end
        if newTarget == lp.UserId and ballWasMine then
            -- bola voltou pra mim
            parryDone   = false
            ballWasMine = false
        end
        if newTarget ~= lp.UserId then
            preArmed = false
        end
    end

    -- HighlightTarget me apontou = bola vindo em breve
    if newHighlight == lp.UserId and newTarget ~= lp.UserId then
        preArmed = true
    end

    BallSync.Speed             = newSpeed
    BallSync.TargetID          = newTarget
    BallSync.RealPosition      = newPos
    BallSync.Grace             = newGrace
    BallSync.Locked            = newLocked
    BallSync.Teleported        = newTeleported
    BallSync.DeflectDirInterp  = newDeflectDI
    BallSync.HighlightTargetID = newHighlight
end)

-- ================== CLASH DETECTION ==================
local ClashState = {
    Active             = false,
    LastActivationTime = 0,
    CurrentOpponent    = nil,
}

local TargetHistory = {}
local lastClashTarget = nil

local function updateClashDetection(newTargetID, ballPos, hrp)
    if newTargetID == lastClashTarget then return end
    lastClashTarget = newTargetID
    if not hrp then return end

    local dist = (hrp.Position - ballPos).Magnitude
    local now  = tick()

    table.insert(TargetHistory, 1, { id = newTargetID, t = now })
    if #TargetHistory > Config.clashHistorySize then table.remove(TargetHistory) end

    if #TargetHistory >= 3 then
        local timeGap       = TargetHistory[1].t - TargetHistory[3].t
        local isAlternating = (
            TargetHistory[1].id == lp.UserId and
            TargetHistory[3].id == lp.UserId
        )
        local speedOk = dist < Config.clashCriticalDist or BallSync.Speed >= Config.clashMinSpeed
        if isAlternating and timeGap < Config.clashTimeWindow and dist < Config.clashMinDist and speedOk then
            if not ClashState.Active then
                spamAccum = getgenv().__deltaV7_spamInterval * getgenv().__deltaV7_spamCapPerFrame
            end
            ClashState.Active             = true
            ClashState.LastActivationTime = now
            ClashState.CurrentOpponent    = TargetHistory[2].id
            clashSpamOn                   = true
            setState("clash")
        end
    end

    if newTargetID == lp.UserId and dist < Config.clashCriticalDist then
        if not ClashState.Active then
            spamAccum = getgenv().__deltaV7_spamInterval * getgenv().__deltaV7_spamCapPerFrame
        end
        ClashState.Active             = true
        ClashState.LastActivationTime = now
        clashSpamOn                   = true
        setState("clash")
    end
end

local function stopClash()
    if ClashState.Active then
        ClashState.Active = false
        clashSpamOn       = false
        spamAccum         = 0
        parryDone         = false
        if State.current == "clash" then setState("normal") end
    end
end

