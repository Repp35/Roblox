local function sendParry()
    local char = lp and lp.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local ballModel = getBallModel()
    if not ballModel or not ballModel.Parent then return end

    if parryRemote then
        pcall(function()
            parryRemote:FireServer(PARRY_ARG, hrp.CFrame, ballModel.CFrame)
        end)
    end

    if touchTapEvent then
        pcall(function() touchTapEvent:Fire() end)
    end
end

-- ================== SPAM LOOP ==================
local toggleButton
local spamConn = nil

local function updateGUI()
    if not toggleButton then return end
    toggleButton.Text             = spamOn and "ON" or "OFF"
    toggleButton.BackgroundColor3 = spamOn
        and Color3.fromRGB(50, 220, 50)
        or  Color3.fromRGB(220, 50, 50)
end

local function startSpamLoop()
    if spamConn then spamConn:Disconnect() end
    spamConn = RS.Heartbeat:Connect(function(dt)
        local active = spamOn or clashSpamOn
        if not active then
            spamAccum = 0
            return
        end

        local interval = getgenv().__deltaV7_spamInterval
        local cap      = getgenv().__deltaV7_spamCapPerFrame
        spamAccum = math.min(spamAccum + dt, interval * cap)

        local fired = 0
        while spamAccum >= interval and fired < cap do
            -- Anti-miss: checa alvo dentro do loop de spam
            if not (spamOn or (clashSpamOn and BallSync.TargetID == lp.UserId)) then
                spamAccum = 0
                break
            end
            sendParry()
            spamAccum = spamAccum - interval
            fired     = fired + 1
        end
    end)
end

local function setSpam(v)
    if spamOn == v then return end
    spamOn = v
    getgenv().__deltaV7_spamActive = v
    if v then
        spamAccum = getgenv().__deltaV7_spamInterval * getgenv().__deltaV7_spamCapPerFrame
        setState("spam")
    else
        spamAccum = 0
        parryDone = false
        setState("normal")
    end
    updateGUI()
end

getgenv().__deltaV7_setSpam = function(v) setSpam(v) end

startSpamLoop()

