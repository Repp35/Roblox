-- ================== CPS DINÂMICO ==================
local function getRealCPSLimit()
    local v = WS:GetAttribute("CPS_LIMIT")
    if v and type(v) == "number" and v > 0 then return v end
    return 25
end

-- FIX: sliding window com pointer em vez de table.remove
-- Evita O(n²) em CPS alto — só avança o índice de início
local fireTimestamps = {}
local tsHead = 1  -- pointer pro início da janela válida

local function _cleanTimestamps()
    local now = tick()
    while tsHead <= #fireTimestamps and now - fireTimestamps[tsHead] >= 1 do
        tsHead = tsHead + 1
    end
    -- reset da tabela quando ficar grande demais (evita crescimento infinito)
    if tsHead > 200 then
        local fresh = {}
        for i = tsHead, #fireTimestamps do
            fresh[#fresh + 1] = fireTimestamps[i]
        end
        fireTimestamps = fresh
        tsHead = 1
    end
end

-- FIX: canFire e canSpam unificados — limpeza acontece uma vez só
local function canFireWith(fraction)
    _cleanTimestamps()
    local active = #fireTimestamps - tsHead + 1
    return active < math.floor(getRealCPSLimit() * fraction)
end

local function sendParry()
    if not canFireWith(1.0) then return false end
    fireTimestamps[#fireTimestamps + 1] = tick()
    if _parryRemote then _parryRemote:FireServer(2.933813859058389e+76) end
    if touchTapEvent then touchTapEvent:Fire() end
    return true
end

local function canSpam()
    return canFireWith(0.80)
end

