-- ============================================================
-- HEARTBEAT — Auto Parry estilo Tek/Phantom [5]
-- ============================================================
local pingTimer = 0

local function bind(ch)
    setupCharacter(ch)

    local ballProcessedLocal = false
    local lastProcessResetL  = 0
    local ballResetAt        = 0
    local lastBallPos        = nil

    local conn
    conn = RS.Heartbeat:Connect(function(dt)
        local ch2 = getgenv().__deltaV3_character
        local hrp = getgenv().__deltaV3_rootPart
        if not (ch2 and ch2.Parent and hrp and hrp.Parent) then
            conn:Disconnect()
            return
        end

        local now = tick()

        -- Ping atualizado a cada 2s
        pingTimer = pingTimer + dt
        if pingTimer >= 2 then
            pingTimer = 0
            task.spawn(updatePing)
        end

        -- Clash decay
        if ClashState.Active and (now - ClashState.LastActivationTime) > Config.clashDecayTime then
            resetClash()
        end

        -- Clash spam
        if getgenv().__deltaV3_autoClashOn and ClashState.Active and BallSync.TargetID == lp.UserId then
            performClashBurst()
        end

        if spamOn then return end
        if not getgenv().__deltaV3_autoParryOn then return end

        -- Reset ballProcessed
        local resetInt = ClashState.Active and Config.processResetClash or Config.processResetInterval
        if ballProcessedLocal and (now - lastProcessResetL) >= resetInt then
            ballProcessedLocal = false
        end

        local b = getgenv().__deltaV3_ball
        if not b or not b.Parent then
            if not getgenv().__deltaV3_ball then
                getgenv().__deltaV3_ball = WS:FindFirstChild("GameBall", true)
            end
            return
        end

        local ballPos = BallSync.RealPosition ~= Vector3.zero and BallSync.RealPosition or b.Position

        -- [5 bugfix] Detecta reset de bola (teleporte grande)
        if lastBallPos then
            local jump = (ballPos - lastBallPos).Magnitude
            if jump > Config.ballResetThresh then
                -- Bola resetou: libera o processed apos breve lockout
                ballProcessedLocal = true
                lastProcessResetL  = now
                ballResetAt        = now
                resetClash()
                lastBallPos = ballPos
                return
            end
        end
        lastBallPos = ballPos

        -- Lockout pos-reset
        if (now - ballResetAt) < Config.ballResetLockout then return end

        local hrpPos = hrp.Position
        local dist   = (hrpPos - ballPos).Magnitude

        -- Atualiza clash detection
        if BallSync.TargetID ~= -999 then
            updateClashDetection(BallSync.TargetID, ballPos)
        end

        -- [5] Target check
        if BallSync.TargetID ~= lp.UserId then return end

        -- [5] Threshold dinamico Tek/Phantom
        local timeToReach = dist / math.max(BallSync.Speed, 1)
        local threshold   = math_clamp(
            0.12 + (smoothedPing * 1.05) + Config.manualPingOffset,
            0.05, 0.55
        )

        if timeToReach <= threshold and not ballProcessedLocal then
            sendParry()
            ballProcessedLocal = true
            lastProcessResetL  = now
        end
    end)

    getgenv().__na_aex_conn = conn

    ch.AncestryChanged:Connect(function(_, p)
        if not p then
            conn:Disconnect()
            setSpam(false)
            resetClash()
            ballProcessedLocal = false
            lastBallPos        = nil
            auraOuter.Transparency = 1
            auraInner.Transparency = 1
        end
    end)
end

