local function bind(ch)
    setupCharacter(ch)

    local hrp       = ch:WaitForChild("HumanoidRootPart", 10)
    local running   = true
    local lastBallPos  = nil
    local ballResetAt  = 0
    local vel          = Vector3.zero
    local lastBP       = nil
    local lastBT       = nil
    local lastParryTime = 0
    local pingTimer   = 0

    local function getBallVel(b)
        local av = b.AssemblyLinearVelocity
        if typeof(av) == "Vector3" and av.Magnitude > 0.1 then
            return av
        end
        return nil
    end

    task.spawn(function()
        while running do
            local dt  = task.wait(0.016)
            local now = tick()

            if not (ch and ch.Parent and hrp and hrp.Parent) then continue end

            pingTimer = pingTimer + dt
            if pingTimer >= 2 then
                pingTimer = 0
                task.spawn(updatePing)
            end

            -- Clash decay
            if ClashState.Active and (now - ClashState.LastActivationTime) > Config.clashDecayTime then
                stopClash()
            end

            -- Fallback reset
            if ballProcessed and (now - lastProcessReset) >= Config.processResetInt then
                ballProcessed = false
            end

            if spamOn then continue end
            if not getgenv().__deltaV5_autoParryOn then continue end

            local b = BallRep and BallRep.syncData and GameInfo and GameInfo.BallModel
            if not (b and b.Parent) then continue end

            local bp = b.Position

            -- Detecta reset
            if lastBallPos then
                local jump = (bp - lastBallPos).Magnitude
                if jump > Config.ballResetThresh then
                    ballProcessed    = true
                    lastProcessReset = now
                    ballResetAt      = now
                    vel              = Vector3.zero
                    lastBP, lastBT   = nil, nil
                    lastBallPos      = bp
                    continue
                end
            end
            lastBallPos = bp

            if (now - ballResetAt) < Config.ballResetLockout then continue end

            -- Clash detection
            local currentTarget = BallSync.TargetID
            if currentTarget and currentTarget > 0 then
                updateClashDetection(currentTarget, bp, hrp)
            end

            -- Velocidade (usa BallSync primeiro, depois fallback)
            local av = BallRep and BallRep.syncData and BallRep.syncData.Speed or getBallVel(b)
            if av then
                if typeof(av) == "number" then
                    vel = Vector3.new(0, 0, av)
                else
                    vel    = av
                end
                lastBT, lastBP = now, bp
            elseif not lastBT then
                lastBT, lastBP = now, bp
            else
                local dtt = now - lastBT
                if dtt > 0 then
                    local raw = (bp - lastBP) / dtt
                    local a   = dt / (Config.velSmooth + dt)
                    vel       = vel + (raw - vel) * a
                    lastBT, lastBP = now, bp
                end
            end

            local hrpPos = hrp.Position
            local spd    = BallRep and BallRep.syncData and BallRep.syncData.Speed or vel.Magnitude
            local d      = (bp - hrpPos).Magnitude
            local app    = vel:Dot(hrpPos - bp) > 0
            local tgt    = (BallSync.TargetID == lp.UserId)
            local tImp   = spd > 1 and (d / spd) or 1000000
            local ping   = getPingCompensation()

            -- CÁLCULO CRÍTICO: Distância com compensação agressiva
            local activationDist = Config.killDistance + (spd * (Config.distanceMultiplier + (ping * 0.5)))

            local can = tgt and app and spd > 5
                and d <= activationDist
                and tImp <= (Config.maxImpactTime + ping)

            if can and not ballProcessed then
                sendParry()
                ballProcessed    = true
                lastProcessReset = now
                setState("normal")
            end
        end
    end)

    ch.AncestryChanged:Connect(function(_, p)
        if not p then
            running = false
            setSpam(false)
            stopClash()
            ballProcessed = false
            ballLeftMe    = false
            lastBallPos   = nil
            updateGUI()
        end
    end)

    getgenv().__na_aex_conn = { Disconnect = function() running = false end }
end

