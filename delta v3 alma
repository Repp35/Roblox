local smoothedPing = 0.05
local function updatePing()
    local ok, raw = pcall(function() return Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000 end)
    if ok and type(raw) == "number" and raw > 0 then
        smoothedPing = (smoothedPing * (1 - Config.pingSmooth)) + (raw * Config.pingSmooth)
    end
end
local function getPingCompensation()
    return math_clamp(smoothedPing * Config.pingMultiplier + Config.pingOffset, Config.pingMin, Config.pingMax)
end

