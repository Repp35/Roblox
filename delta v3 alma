-- ================== STATE ==================
local State = { current = "normal", lastTransition = 0 }
local function setState(s)
    if State.current == s then return end
    State.current = s State.lastTransition = tick()
end

-- ================== CLASH ==================
local ClashState    = { Active = false, LastActivationTime = 0, CurrentOpponent = nil }
local TargetHistory = {}
local lastTarget    = nil
local spamOn        = false
local clashSpamOn   = false
local spamAccum     = 0

local function hasNearbyOpponent()
    local hrp = Cache.RootPart
    if not hrp then return false end
    local myPos = hrp.Position
    for _, player in ipairs(Plrs:GetPlayers()) do
        if player == lp then continue end
        local ch = player.Character if not ch then continue end
        local root = ch:FindFirstChild("HumanoidRootPart") if not root then continue end
        if (myPos - root.Position).Magnitude <= Config.clashOpponentDist then return true end
    end
    return false
end

local function activateClash(opponentID)
    if not ClashState.Active then
        local interval = getgenv().__deltaV3_spamInterval or (1 / getRealCPSLimit())
        local cap      = getgenv().__deltaV3_spamCapPerFrame or Config.spamCapPerFrame
        spamAccum = interval * cap
    end
    ClashState.Active             = true
    ClashState.LastActivationTime = tick()
    ClashState.CurrentOpponent    = opponentID
    clashSpamOn                   = true
    setState("clash")
end

local function updateClashDetection(newTargetID, ballPos, ballVel)
    if newTargetID == lastTarget then return end
    lastTarget = newTargetID
    if not Cache.RootPart then return end
    if not getgenv().__deltaV3_autoClashOn then return end
    if isLocked() then return end
    if (tick() - ballResetAt) < Config.clashResetGuard then return end

    local hrpPos = Cache.RootPart.Position
    local dist   = (hrpPos - ballPos).Magnitude
    local now    = tick()
    local spd    = getSyncSpeed() or (ballVel and ballVel.Magnitude) or 0

    table.insert(TargetHistory, 1, { id = newTargetID, t = now })
    if #TargetHistory > Config.clashHistorySize then table.remove(TargetHistory) end

    local ballComing = (newTargetID == lp.UserId)
    if ballVel and ballVel.Magnitude > 1 then
        ballComing = ballVel.Unit:Dot((hrpPos - ballPos).Unit) >= Config.clashDotThresh
    end

    if #TargetHistory >= 3 then
        local timeGap       = TargetHistory[1].t - TargetHistory[3].t
        local isAlternating = TargetHistory[1].id == lp.UserId
                           and TargetHistory[2].id ~= lp.UserId
                           and TargetHistory[3].id == lp.UserId
        local speedOk = spd >= Config.clashMinSpeed or dist < Config.clashCriticalDist
        local distOk  = dist < Config.clashMinDist
        if isAlternating and timeGap < Config.clashTimeWindow and distOk and speedOk and ballComing then
            activateClash(TargetHistory[2].id) return
        end
    end

    if newTargetID == lp.UserId and dist < Config.clashCriticalDist and ballComing and spd >= Config.clashMinSpeed then
        activateClash(nil) return
    end
    if newTargetID == lp.UserId and ballComing and hasNearbyOpponent() then
        activateClash(nil)
    end
end

local function stopClash()
    if ClashState.Active then
        ClashState.Active          = false
        ClashState.CurrentOpponent = nil
        clashSpamOn                = false
        spamAccum                  = 0
        ballProcessed              = false
        if State.current == "clash" then setState("normal") end
    end
end

-- FIX: watchdog no Heartbeat — garante que clashSpamOn nunca fica
-- travado se o loop principal pausar ou o personagem morrer no meio
RS.Heartbeat:Connect(function()
    if ClashState.Active and (tick() - ClashState.LastActivationTime) > Config.clashDecayTime * 2 then
        stopClash()
    end
end)

-- ================== SPAM LOOP ==================
local toggleButton = nil
local spamConn     = nil

local function updateGUI()
    if not toggleButton then return end
    toggleButton.Text             = spamOn and "ON" or "OFF"
    toggleButton.BackgroundColor3 = spamOn
        and Color3.fromRGB(50, 220, 50)
        or  Color3.fromRGB(220, 50, 50)
end

local function startSpamLoop()
    if spamConn then spamConn:Disconnect() end
    spamConn = RS.Heartbeat:Connect(function(dt)
        local active = spamOn or clashSpamOn
        if not active then
            spamAccum = 0
            return
        end

        local interval = getgenv().__deltaV3_spamInterval or (1 / getRealCPSLimit())
        local cap      = getgenv().__deltaV3_spamCapPerFrame or Config.spamCapPerFrame

        spamAccum = math.min(spamAccum + dt, interval * cap)

        local fired = 0
        while spamAccum >= interval and fired < cap do
            if canSpam() then sendParry() end
            spamAccum = spamAccum - interval
            fired     = fired + 1
        end
    end)
end

local function setSpam(v)
    if spamOn == v then return end
    spamOn = v
    getgenv().__deltaV3_spamActive = v
    if v then
        local interval = getgenv().__deltaV3_spamInterval or (1 / getRealCPSLimit())
        local cap      = getgenv().__deltaV3_spamCapPerFrame or Config.spamCapPerFrame
        spamAccum = interval * cap
        setState("spam")
    else
        spamAccum     = 0
        ballProcessed = false
        setState("normal")
    end
    updateGUI()
end

getgenv().__deltaV3_setSpam = setSpam
startSpamLoop()

