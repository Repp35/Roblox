local smoothedPing = 0.05
local function updatePing()
    local ok, raw = pcall(function()
        return Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
    end)
    if ok and type(raw) == "number" and raw > 0 then
        smoothedPing = smoothedPing * (1 - Config.pingSmooth) + raw * Config.pingSmooth
    end
end

-- ============================================================
-- CLASH
-- ============================================================
local ClashState = {
    Active             = false,
    LastActivationTime = 0,
    IsBursting         = false,
    CurrentOpponent    = nil,
}
local TargetHistory = {}
local lastTarget    = nil
local ballProcessed = false
local lastProcessReset = 0

local function resetClash()
    ClashState.Active          = false
    ClashState.IsBursting      = false
    ClashState.CurrentOpponent = nil
    TargetHistory = {}
    lastTarget    = nil
end

local function updateClashDetection(newTargetID, ballPos)
    if newTargetID == lastTarget then return end

    -- [5 bugfix] Quando target muda PARA o jogador local, reseta o ballProcessed imediatamente
    if newTargetID == lp.UserId then
        ballProcessed    = false
        lastProcessReset = 0
    end

    lastTarget = newTargetID

    local hrp = getgenv().__deltaV3_rootPart
    if not hrp or not hrp.Parent then return end
    local dist = (hrp.Position - ballPos).Magnitude
    local now  = tick()

    table.insert(TargetHistory, 1, {id=newTargetID, t=now})
    if #TargetHistory > 6 then table.remove(TargetHistory) end

    if #TargetHistory >= 3 then
        local timeGap       = TargetHistory[1].t - TargetHistory[3].t
        local isAlternating = (TargetHistory[1].id == lp.UserId and TargetHistory[3].id == lp.UserId)
        if isAlternating and timeGap < 0.6 and dist < Config.clashMinDist then
            ClashState.Active             = true
            ClashState.LastActivationTime = now
            ClashState.CurrentOpponent    = TargetHistory[2].id
        end
    end

    if newTargetID == lp.UserId and dist < Config.clashCriticalDist then
        ClashState.Active             = true
        ClashState.LastActivationTime = now
    end
end

local function performClashBurst()
    if ClashState.IsBursting then return end
    ClashState.IsBursting = true
    task.spawn(function()
        for i = 1, Config.clashBurstCount do
            if not ClashState.Active then break end
            for _ = 1, Config.clashBurstSize do sendParry() end
            task.wait(Config.clashBurstInterval)
        end
        ClashState.IsBursting = false
    end)
end

-- ============================================================
-- SPAM
-- ============================================================
local spamOn   = false
local spamThread = nil

local updateSpamGUI  -- forward

local function getActiveInterval()
    if getgenv().__deltaV3_calibrated then
        return getgenv().__deltaV3_calibratedInterval
            or getgenv().__deltaV3_spamInterval
            or Config.spamInterval
    end
    return getgenv().__deltaV3_spamInterval or Config.spamInterval
end

local function getActivePingOffset()
    if getgenv().__deltaV3_calibrated then
        return getgenv().__deltaV3_pingOffset or 0
    end
    return 0
end

local function getActiveBurst()
    if getgenv().__deltaV3_calibrated then
        return getgenv().__deltaV3_burstCount or 1
    end
    return 1
end

local function runSpamLoop()
    local startT   = os.clock()
    local n        = 0
    local interval = getActiveInterval()
    local pOff     = getActivePingOffset()
    local burst    = getActiveBurst()

    while spamOn do
        n = n + 1
        local nextFire = startT + n * interval - pOff
        local now      = os.clock()
        local diff     = nextFire - now

        if diff > 0.001 then
            task.wait(diff)
        else
            task.wait()
            if (os.clock() - nextFire) > interval * 3 then
                startT = os.clock(); n = 0
            end
        end

        if not spamOn then break end

        for b = 1, burst do
            pcall(sendParry)
            if b < burst then task.wait(0.001) end
        end
    end
end

local function setSpam(v)
    if spamOn == v then return end
    spamOn = v
    getgenv().__deltaV3_spamActive = v
    if updateSpamGUI then updateSpamGUI() end
    if v then spamThread = task.spawn(runSpamLoop) end
end

getgenv().__deltaV3_setSpam = function(v) setSpam(v) end

-- ============================================================
-- CALIBRACAO [6] Maximizada — 60fps/50ms ≈ 120fps/10ms sem calib
-- ============================================================
getgenv().__deltaV3_applyCalibration = function(fps, ping)
    local pingS     = ping / 1000
    local frameTime = 1 / fps

    -- [6] Referencia: 120fps / 10ms
    local refPing      = 0.010
    local refFrameTime = 1 / 120

    -- Diferenca de ping e de frame que precisa ser compensada
    local extraPing  = math_clamp(pingS - refPing, 0, 0.4)
    local extraFrame = math_clamp(frameTime - refFrameTime, 0, 0.05)

    -- Offset manual para compensar ping + fps mais baixo
    local calibOffset = extraPing * 1.05 + extraFrame * 0.8
    Config.manualPingOffset = math_clamp(calibOffset, 0.01, 0.35)

    -- Alinha o intervalo de spam ao frame boundary
    local rawInterval   = getgenv().__deltaV3_spamIntervalRaw
        or getgenv().__deltaV3_spamInterval
        or Config.spamInterval
    local framesPerSpam   = math.max(1, math.floor(rawInterval / frameTime + 0.5))
    local alignedInterval = framesPerSpam * frameTime
    local bCount          = (pingS >= 0.050) and 2 or 1

    getgenv().__deltaV3_calibratedInterval = alignedInterval
    getgenv().__deltaV3_pingOffset         = pingS * 0.5  -- antecipa metade do ping no spam
    getgenv().__deltaV3_burstCount         = bCount
    getgenv().__deltaV3_effectiveCps       = math.floor(1 / alignedInterval + 0.5)
    getgenv().__deltaV3_frameTime          = frameTime
    getgenv().__deltaV3_framesPerSpam      = framesPerSpam
    getgenv().__deltaV3_calibrated         = true

    if spamOn then
        spamOn = false
        task.wait(0.05)
        setSpam(true)
    end
end

-- Aplica calibracao salva ao iniciar
if getgenv().__deltaV3_calibrated
    and getgenv().__deltaV3_calibFps ~= nil
    and getgenv().__deltaV3_calibFps ~= ""
then
    local fps  = tonumber(getgenv().__deltaV3_calibFps)
    local ping = tonumber(getgenv().__deltaV3_calibPing)
    if fps and ping then
        task.defer(function()
            getgenv().__deltaV3_applyCalibration(fps, ping)
        end)
    end
end

