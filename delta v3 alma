local function startSpamLoop()
    if spamConn then spamConn:Disconnect() end
    spamConn = RS.Heartbeat:Connect(function(dt)
        local active = spamOn or clashSpamOn
        if not active then
            spamAccum = 0
            return
        end

        local interval = getgenv().__deltaV6_spamInterval
        local cap      = getgenv().__deltaV6_spamCapPerFrame
        spamAccum = math.min(spamAccum + dt, interval * cap)

        local fired = 0
        while spamAccum >= interval and fired < cap do
            sendParry()
            spamAccum = spamAccum - interval
            fired     = fired + 1
        end
    end)
end

local function setSpam(v)
    if spamOn == v then return end
    spamOn = v
    getgenv().__deltaV6_spamActive = v
    if v then
        spamAccum = getgenv().__deltaV6_spamInterval * getgenv().__deltaV6_spamCapPerFrame
        setState("spam")
    else
        spamAccum     = 0
        ballProcessed = false
        setState("normal")
    end
    updateGUI()
end

getgenv().__deltaV6_setSpam = function(v) setSpam(v) end

