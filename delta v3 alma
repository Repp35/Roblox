-- ================== PING ==================
-- declarado ANTES do BallSync callback pra closure funcionar
local smoothedPing = 0.05

local function updatePing()
    local ok, raw = pcall(function()
        return Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
    end)
    if ok and type(raw) == "number" and raw > 0 then
        smoothedPing = (smoothedPing * (1 - Config.pingSmooth)) + (raw * Config.pingSmooth)
    end
end

getgenv().__deltaV3_applyCalibration = function(fps, ping)
    if type(ping) == "number" and ping > 0 then
        smoothedPing = ping / 1000
    end
    if type(fps) == "number" and fps > 0 then
        local interval = getgenv().__deltaV3_spamInterval or Config.spamInterval
        getgenv().__deltaV3_spamCapPerFrame = math.max(1, math.ceil(fps * interval * 1.2))
    end
end

local function getPingCompensation()
    return math_clamp(
        smoothedPing * Config.pingMultiplier + Config.pingOffset,
        Config.pingMin, Config.pingMax
    )
end

-- ================== BALL SYNC ==================
local BallSync      = { RealPosition = Vector3.zero, Speed = 0, TargetID = -999 }
local ballProcessed      = false
local ballLeftMe         = false
local lastProcessReset   = 0
local ballCameFromReset  = false   -- bola veio de reset, não de troca normal
local lastTargetToMe     = 0       -- tick quando TargetID virou meu

local ballSyncRemote = RSrv:WaitForChild("Remotes", 5)
ballSyncRemote = ballSyncRemote and ballSyncRemote:FindFirstChild("BallSyncData")

if ballSyncRemote then
    ballSyncRemote.OnClientEvent:Connect(function(data)
        if typeof(data) ~= "table" then return end
        if data.RealPosition then BallSync.RealPosition = data.RealPosition end
        if typeof(data.Speed) == "number" then
            BallSync.Speed = data.Speed
        elseif type(data.Speed) == "table" and data.Speed.Magnitude then
            BallSync.Speed = data.Speed.Magnitude
        end
        if data.TargetPlayerID then
            local newID = data.TargetPlayerID
            if newID ~= BallSync.TargetID then
                if BallSync.TargetID == lp.UserId then
                    ballLeftMe = true           -- bola saiu de mim
                end
                if newID == lp.UserId then
                    if ballLeftMe then
                        -- troca normal: bola passou por outro jogador → libera imediatamente
                        ballProcessed   = false
                        ballLeftMe      = false
                        ballCameFromReset = false
                    else
                        -- veio do reset: marca e aplica mini lockout
                        ballCameFromReset = true
                        ballProcessed    = true   -- bloqueia por ora
                        lastProcessReset = tick() -- vai liberar após 0.15s
                    end
                    lastTargetToMe = tick()
                end
            end
            BallSync.TargetID = newID
        end

        -- [SUPER AUTO PARRY] disparo direto no callback: zero delay de loop
        if BallSync.TargetID == lp.UserId and not ballProcessed
            and not spamOn
            and getgenv().__deltaV3_autoParryOn
            and Cache.RootPart
            and BallSync.Speed > Config.minSpeed   -- ignora bola parada/resetando
            and not ballCameFromReset               -- aguarda mini lockout pós-reset
        then
            local dist        = (Cache.RootPart.Position - BallSync.RealPosition).Magnitude
            local timeToReach = dist / math.max(BallSync.Speed, 1)
            local threshold   = math_clamp(0.12 + (smoothedPing * 1.05) + 0.045, 0.05, 0.55)
            if timeToReach <= threshold then
                local b = getBall()
                if parryRemote then
                    parryRemote:FireServer(2.933813859058389e+76, Cache.RootPart.CFrame,
                        b and b.Parent and b.CFrame or Cache.RootPart.CFrame)
                end
                if touchTapEvent then touchTapEvent:Fire() end
                ballProcessed    = true
                lastProcessReset = tick()
            end
        end
    end)
end

-- ================== STATE MACHINE ==================
local State = { current = "normal", lastTransition = 0 }

local function setState(s)
    if State.current == s then return end
    State.current        = s
    State.lastTransition = tick()
end

-- ================== CLASH ==================
local ClashState = {
    Active             = false,
    LastActivationTime = 0,
    CurrentOpponent    = nil,
}

local TargetHistory = {}
local lastTarget    = nil

local function updateClashDetection(newTargetID, ballPos)
    if newTargetID == lastTarget then return end
    lastTarget = newTargetID

    if not Cache.RootPart then return end
    local dist = (Cache.RootPart.Position - ballPos).Magnitude
    local now  = tick()

    table.insert(TargetHistory, 1, { id = newTargetID, t = now })
    if #TargetHistory > Config.clashHistorySize then table.remove(TargetHistory) end

    if #TargetHistory >= 3 then
        local timeGap       = TargetHistory[1].t - TargetHistory[3].t
        local isAlternating = (
            TargetHistory[1].id == lp.UserId and
            TargetHistory[3].id == lp.UserId
        )
        local speedOk = dist < Config.clashCriticalDist or BallSync.Speed >= Config.clashMinSpeed
        if isAlternating and timeGap < Config.clashTimeWindow and dist < Config.clashMinDist and speedOk then
            if not ClashState.Active then
                -- [FIX] enche acumulador imediatamente ao ativar clash
                local interval = getgenv().__deltaV3_spamInterval    or Config.spamInterval
                local cap      = getgenv().__deltaV3_spamCapPerFrame or Config.spamCapPerFrame
                spamAccum = interval * cap
            end
            ClashState.Active             = true
            ClashState.LastActivationTime = now
            ClashState.CurrentOpponent    = TargetHistory[2].id
            clashSpamOn                   = true
            setState("clash")
        end
    end

    if newTargetID == lp.UserId and dist < Config.clashCriticalDist then
        if not ClashState.Active then
            local interval = getgenv().__deltaV3_spamInterval    or Config.spamInterval
            local cap      = getgenv().__deltaV3_spamCapPerFrame or Config.spamCapPerFrame
            spamAccum = interval * cap
        end
        ClashState.Active             = true
        ClashState.LastActivationTime = now
        clashSpamOn                   = true
        setState("clash")
    end
end

local function stopClash()
    if ClashState.Active then
        ClashState.Active = false
        clashSpamOn       = false
        spamAccum         = 0
        ballProcessed     = false  -- libera auto parry imediatamente
        if State.current == "clash" then setState("normal") end
    end
end

-- ================== SPAM ==================
local spamAccum  = 0
local toggleButton
local spamConn   = nil

local function updateGUI()
    if not toggleButton then return end
    toggleButton.Text             = spamOn and "ON" or "OFF"
    toggleButton.BackgroundColor3 = spamOn
        and Color3.fromRGB(50, 220, 50)
        or  Color3.fromRGB(220, 50, 50)
end

local function startSpamLoop()
    if spamConn then spamConn:Disconnect() end
    spamConn = RS.Heartbeat:Connect(function(dt)
        local active = spamOn or clashSpamOn
        if not active then
            spamAccum = 0
            return
        end
        local interval = getgenv().__deltaV3_spamInterval    or Config.spamInterval
        local cap      = getgenv().__deltaV3_spamCapPerFrame or Config.spamCapPerFrame
        spamAccum = math.min(spamAccum + dt, interval * cap)
        local fired = 0
        while spamAccum >= interval and fired < cap do
            sendParry()
            spamAccum = spamAccum - interval
            fired     = fired + 1
        end
    end)
end

local function setSpam(v)
    if spamOn == v then return end
    spamOn = v
    getgenv().__deltaV3_spamActive = v
    if v then
        local interval = getgenv().__deltaV3_spamInterval    or Config.spamInterval
        local cap      = getgenv().__deltaV3_spamCapPerFrame or Config.spamCapPerFrame
        spamAccum = interval * cap
        setState("spam")
    else
        spamAccum     = 0
        ballProcessed = false  -- libera auto parry imediatamente ao desativar spam
        setState("normal")
    end
    updateGUI()
end

getgenv().__deltaV3_setSpam = function(v) setSpam(v) end

startSpamLoop()

UIS.InputBegan:Connect(function(inp, gpe)
