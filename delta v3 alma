                    ballProcessed = false
                    ballLeftMe    = false
                end
            end
            BallSync.TargetID = newID
        end
    end)
end

-- ================== STATE MACHINE ==================
local State = { current = "normal", lastTransition = 0 }

local function setState(s)
    if State.current == s then return end
    State.current        = s
    State.lastTransition = tick()
end

-- ================== CLASH ==================
local ClashState = {
    Active             = false,
    LastActivationTime = 0,
    CurrentOpponent    = nil,
}

local TargetHistory = {}
local lastTarget    = nil

local function updateClashDetection(newTargetID, ballPos)
    if newTargetID == lastTarget then return end
    lastTarget = newTargetID

    if not Cache.RootPart then return end
    local dist = (Cache.RootPart.Position - ballPos).Magnitude
    local now  = tick()

    table.insert(TargetHistory, 1, { id = newTargetID, t = now })
    if #TargetHistory > Config.clashHistorySize then table.remove(TargetHistory) end

    if #TargetHistory >= 3 then
        local timeGap       = TargetHistory[1].t - TargetHistory[3].t
        local isAlternating = (
            TargetHistory[1].id == lp.UserId and
            TargetHistory[3].id == lp.UserId
        )
        local speedOk = dist < Config.clashCriticalDist or BallSync.Speed >= Config.clashMinSpeed
        if isAlternating and timeGap < Config.clashTimeWindow and dist < Config.clashMinDist and speedOk then
            if not ClashState.Active then
                local interval = getgenv().__deltaV3_spamInterval    or Config.spamInterval
                local cap      = getgenv().__deltaV3_spamCapPerFrame or Config.spamCapPerFrame
                spamAccum = interval * cap
            end
            ClashState.Active             = true
            ClashState.LastActivationTime = now
            ClashState.CurrentOpponent    = TargetHistory[2].id
            clashSpamOn                   = true
            setState("clash")
        end
    end

    if newTargetID == lp.UserId and dist < Config.clashCriticalDist then
        if not ClashState.Active then
            local interval = getgenv().__deltaV3_spamInterval    or Config.spamInterval
            local cap      = getgenv().__deltaV3_spamCapPerFrame or Config.spamCapPerFrame
            spamAccum = interval * cap
        end
        ClashState.Active             = true
        ClashState.LastActivationTime = now
        clashSpamOn                   = true
        setState("clash")
    end
end

local function stopClash()
    if ClashState.Active then
        ClashState.Active = false
        clashSpamOn       = false
        spamAccum         = 0
        ballProcessed     = false
        if State.current == "clash" then setState("normal") end
    end
end

-- ================== SPAM ==================
local spamAccum  = 0
local toggleButton
local spamConn   = nil

local function updateGUI()
    if not toggleButton then return end
    toggleButton.Text             = spamOn and "ON" or "OFF"
    toggleButton.BackgroundColor3 = spamOn
        and Color3.fromRGB(50, 220, 50)
        or  Color3.fromRGB(220, 50, 50)
end

local function startSpamLoop()
    if spamConn then spamConn:Disconnect() end
    spamConn = RS.Heartbeat:Connect(function(dt)
        local active = spamOn or clashSpamOn
        if not active then
            spamAccum = 0
            return
        end
        local interval = getgenv().__deltaV3_spamInterval    or Config.spamInterval
        local cap      = getgenv().__deltaV3_spamCapPerFrame or Config.spamCapPerFrame
        spamAccum = math.min(spamAccum + dt, interval * cap)
        local fired = 0
        while spamAccum >= interval and fired < cap do
            sendParry()
            spamAccum = spamAccum - interval
            fired     = fired + 1
        end
    end)
end

local function setSpam(v)
    if spamOn == v then return end
    spamOn = v
    getgenv().__deltaV3_spamActive = v
    if v then
        local interval = getgenv().__deltaV3_spamInterval    or Config.spamInterval
        local cap      = getgenv().__deltaV3_spamCapPerFrame or Config.spamCapPerFrame
        spamAccum = interval * cap
        setState("spam")
    else
        spamAccum     = 0
        ballProcessed = false
        setState("normal")
    end
    updateGUI()
end

getgenv().__deltaV3_setSpam = function(v) setSpam(v) end

startSpamLoop()

UIS.InputBegan:Connect(function(inp, gpe)
