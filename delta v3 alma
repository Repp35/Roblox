-- ================== AURA ==================
local OUTER_TRANSPARENCY = 0.18
local INNER_TRANSPARENCY = 0.9
local AREA_COLOR         = Color3.fromRGB(255, 255, 255)
local SPAM_COLOR         = Color3.fromRGB(255, 50,  50)
local CLASH_COLOR        = Color3.fromRGB(255, 200, 50)
local GRACE_COLOR        = Color3.fromRGB(50,  255, 180)

local function createAuraPart(name)
    local p = Instance.new("Part")
    p.Name = name p.Shape = Enum.PartType.Ball p.Material = Enum.Material.ForceField
    p.Anchored = true p.CanCollide = false p.CastShadow = false
    p.Transparency = 1 p.Color = AREA_COLOR p.Parent = WS
    return p
end
local auraOuter        = createAuraPart("DeltaAuraOuter")
local auraInner        = createAuraPart("DeltaAuraInner")
local lastVisualUpdate = 0

local auraConn = RS.RenderStepped:Connect(function()
    local now = tick()
    if (now - lastVisualUpdate) < 0.015 then return end
    lastVisualUpdate = now

    local hrp = Cache.RootPart
    if not getgenv().__deltaV3_auraOn or not hrp or not hrp.Parent then
        auraOuter.Transparency = 1 auraInner.Transparency = 1 return
    end

    local syncSpd   = getSyncSpeed()
    local b         = getBall()
    local realSpeed = syncSpd or (b and b.Parent and b.AssemblyLinearVelocity.Magnitude) or 45
    local grace     = isGraceActive()

    local baseRad = math_clamp(realSpeed * Config.radiusWin + Config.radiusOff, Config.minRadius, Config.maxRadius)
        + Config.radiusPre + Config.activationDistanceOffset
    local rad = ClashState.Active and (baseRad * Config.clashRadMult)
             or grace             and (baseRad * Config.graceRadiusMult)
             or baseRad

    auraOuter.CFrame = hrp.CFrame auraInner.CFrame = hrp.CFrame
    auraOuter.Size   = Vector3.new(rad * 2, rad * 2, rad * 2)
    auraInner.Size   = Vector3.new((rad - 0.5) * 2, (rad - 0.5) * 2, (rad - 0.5) * 2)

    local targetColor = ClashState.Active and CLASH_COLOR
                     or spamOn            and SPAM_COLOR
                     or grace             and GRACE_COLOR
                     or AREA_COLOR
    auraOuter.Color        = auraOuter.Color:Lerp(targetColor, 0.3)
    auraOuter.Transparency = OUTER_TRANSPARENCY
    auraInner.Transparency = INNER_TRANSPARENCY
end)

-- ================== LOOP PRINCIPAL ==================
local function bind(ch)
    setupCharacter(ch)
    local hrp     = ch:WaitForChild("HumanoidRootPart", 10)
    local running = true
    local vel     = Vector3.zero
    local lastBP, lastBT = nil, nil
    local lastBallPos    = nil
    local pingTimer      = 0

    local function getBallVel(b)
        local av = b.AssemblyLinearVelocity
        if typeof(av) == "Vector3" and av.Magnitude > 0.1 then return av end
        return nil
    end

    task.spawn(function()
        while running do
            -- FIX: usa o dt real retornado pelo task.wait
            -- em vez de assumir 0.016 fixo
            local dt  = task.wait(0.016)
            local now = tick()

            if not (ch and ch.Parent and hrp and hrp.Parent) then continue end

            pingTimer = pingTimer + dt
            if pingTimer >= 2 then pingTimer = 0 task.spawn(updatePing) end

            if ClashState.Active and (now - ClashState.LastActivationTime) > Config.clashDecayTime then
                stopClash()
            end

            if ballProcessed and (now - lastProcessReset) >= Config.processResetInt then
                ballProcessed = false
            end

            local b = getBall()
            if not (b and b.Parent) then continue end

            local bp     = b.Position
            local hrpPos = hrp.Position

            if lastBallPos then
                local jump = (bp - lastBallPos).Magnitude
                if jump > Config.ballResetThresh then
                    ballProcessed    = true
                    lastProcessReset = now
                    ballResetAt      = now
                    vel              = Vector3.zero
                    lastBP, lastBT   = nil, nil
                    lastBallPos      = bp
                    continue
                end
            end
            lastBallPos = bp

            if (now - ballResetAt) < Config.ballResetLockout then continue end

            local currentTarget = getSyncTarget() or WS:GetAttribute("GameBallTarget")
            if currentTarget and currentTarget > 0 then
                updateClashDetection(currentTarget, bp, getBallVel(b))
            end

            if not getgenv().__deltaV3_autoParryOn then continue end
            if isLocked() then continue end
            -- FIX: parry dorme enquanto spam ativo (igual Phantom)
            -- acorda no frame exato que spam para, sem delay
            if spamOn or clashSpamOn then continue end

            local av = getBallVel(b)
            if av then
                vel = av lastBT, lastBP = now, bp
            elseif not lastBT then
                lastBT, lastBP = now, bp
            else
                local dtt = now - lastBT
                if dtt > 0 then
                    local raw = (bp - lastBP) / dtt
                    local a   = dt / (Config.velSmooth + dt)
                    vel       = vel + (raw - vel) * a
                    lastBT, lastBP = now, bp
                end
            end

            local grace   = isGraceActive()
            local syncSpd = getSyncSpeed()
            local spd     = syncSpd or vel.Magnitude
            local ping    = getPingCompensation()
            local d       = (bp - hrpPos).Magnitude
            local tgt     = tgtOn()

            if grace and tgt and not ballProcessed then
                local graceRad = math_clamp((syncSpd or 45) * Config.radiusWin + Config.radiusOff,
                    Config.minRadius, Config.maxRadius) * Config.graceRadiusMult + Config.radiusPre
                local killThresh = Config.killDistance + (ping * (syncSpd or 45)) + 2
                if d <= graceRad or d <= killThresh then
                    if sendParry() then
                        ballProcessed    = true
                        lastProcessReset = now
                        setState("normal")
                    end
                end
                continue
            end

            local rad  = math_clamp(spd * Config.radiusWin + Config.radiusOff, Config.minRadius, Config.maxRadius) + Config.radiusPre
            local app  = vel.Magnitude > 0.1 and vel:Dot(hrpPos - bp) > 0
            local tImp = spd > 1 and (d / spd) or 1000000
            local can  = tgt and app and spd > Config.minSpeed and d <= rad and tImp <= (Config.maxImpactTime + ping)

            if can and not ballProcessed then
                if sendParry() then
                    ballProcessed    = true
                    lastProcessReset = now
                    setState("normal")
                end
            end
        end
    end)

    ch.AncestryChanged:Connect(function(_, p)
        if not p then
            running = false
            setSpam(false)
            stopClash()
            ballProcessed  = false
            ballLeftMe     = false
            lastBallPos    = nil
            lastSyncTarget = -99999
            auraOuter.Transparency = 1
            auraInner.Transparency = 1
            updateGUI()
        end
    end)

    getgenv().__na_aex_conn = { Disconnect = function() running = false end }
end

