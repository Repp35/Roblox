local function getSyncData()   return br and br.syncData end
local function isGraceActive() local sd = getSyncData() return sd and sd.Grace == true end
local function isLocked()      local sd = getSyncData() return sd and sd.Locked == true end
local function getSyncSpeed()  local sd = getSyncData() if sd and sd.Speed and sd.Speed > 0 then return sd.Speed end return nil end
