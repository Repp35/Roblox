-- Detecta alvo via syncData (primário) ou HighlightTargetPlayerID (secundário)
local function isTargetMe()
    local data = getSyncData()
    if not data then return false end
    if data.TargetPlayerID == lp.UserId then return true end
    if data.HighlightTargetPlayerID == lp.UserId then return true end
    -- Fallback legado
    local ch = lp.Character
    if ch and ch:FindFirstChild("Highlight") then return true end
    if WS:GetAttribute("GameBallTarget") == lp.UserId then return true end
    return false
end

