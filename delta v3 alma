-- ================== CLASH DETECTION ==================
local ClashState = {
    Active             = false,
    LastActivationTime = 0,
    CurrentOpponent    = nil,
}

local TargetHistory = {}
local lastTarget    = nil

local function updateClashDetection(newTargetID, ballPos, hrp)
    if newTargetID == lastTarget then return end
    lastTarget = newTargetID
    if not hrp then return end

    local dist = (hrp.Position - ballPos).Magnitude
    local now  = tick()

    table.insert(TargetHistory, 1, { id = newTargetID, t = now })
    if #TargetHistory > Config.clashHistorySize then table.remove(TargetHistory) end

    if #TargetHistory >= 3 then
        local timeGap       = TargetHistory[1].t - TargetHistory[3].t
        local isAlternating = (
            TargetHistory[1].id == lp.UserId and
            TargetHistory[3].id == lp.UserId
        )
        local speedOk = dist < Config.clashCriticalDist or BallSync.Speed >= Config.clashMinSpeed
        if isAlternating and timeGap < Config.clashTimeWindow and dist < Config.clashMinDist and speedOk then
            if not ClashState.Active then
                spamAccum = getgenv().__deltaV6_spamInterval * getgenv().__deltaV6_spamCapPerFrame
            end
            ClashState.Active             = true
            ClashState.LastActivationTime = now
            ClashState.CurrentOpponent    = TargetHistory[2].id
            clashSpamOn                   = true
            setState("clash")
        end
    end

    if newTargetID == lp.UserId and dist < Config.clashCriticalDist then
        if not ClashState.Active then
            spamAccum = getgenv().__deltaV6_spamInterval * getgenv().__deltaV6_spamCapPerFrame
        end
        ClashState.Active             = true
        ClashState.LastActivationTime = now
        clashSpamOn                   = true
        setState("clash")
    end
end

local function stopClash()
    if ClashState.Active then
        ClashState.Active = false
        clashSpamOn       = false
        spamAccum         = 0
        ballProcessed     = false
        if State.current == "clash" then setState("normal") end
    end
end

-- ================== SEND PARRY ==================
-- Usa Network nativo do jogo — o caminho que o servidor espera
local function sendParry()
    local char = lp and lp.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local ballModel = getBallModel()
    if not ballModel or not ballModel.Parent then return end

    -- ANTI-MISS: só dispara se ainda somos o alvo no momento exato do envio
    -- (cancela cliques residuais se a bola mudou de dono)
    local data = getSyncData()
    if data and data.TargetPlayerID ~= -99999 and data.TargetPlayerID ~= lp.UserId then
        if not (clashSpamOn or spamOn) then return end
    end

    if Net then
        pcall(function()
            Net:CSendEvent(PARRY_EVENT_ID, PARRY_ARG, hrp.CFrame, ballModel.CFrame)
        end)
    elseif parryRemote then
        pcall(function()
            parryRemote:FireServer(PARRY_ARG, hrp.CFrame, ballModel.CFrame)
        end)
    end

    if touchTapEvent then
        pcall(function() touchTapEvent:Fire() end)
    end
end

