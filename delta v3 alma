-- ================== AUTO PARRY LOOP ==================
-- Usa syncData nativo do BallReplicator — sem adivinhação de posição
local function bind(ch)
    setupCharacter(ch)

    local hrp     = ch:WaitForChild("HumanoidRootPart", 10)
    local running = true

    local lastBallPos   = nil
    local ballResetAt   = 0
    local vel           = Vector3.zero
    local lastBP        = nil
    local lastBT        = nil
    local pingTimer     = 0

    task.spawn(function()
        while running do
            local dt  = task.wait(0.016)
            local now = tick()

            if not (ch and ch.Parent and hrp and hrp.Parent) then continue end

            pingTimer = pingTimer + dt
            if pingTimer >= 2 then
                pingTimer = 0
                task.spawn(updatePing)
            end

            -- Clash decay
            if ClashState.Active and (now - ClashState.LastActivationTime) > Config.clashDecayTime then
                stopClash()
            end

            -- Fallback reset do ballProcessed
            if ballProcessed and (now - lastProcessReset) >= Config.processResetInt then
                ballProcessed = false
            end

            if spamOn then continue end
            if not getgenv().__deltaV6_autoParryOn then continue end

            -- ---- Dados da bola via BallReplicator nativo ----
            local data      = getSyncData()
            local ballModel = getBallModel()

            if not (ballModel and ballModel.Parent) then continue end
            if data and data.Locked then continue end  -- bola travada = não rola parry

            local bp = (data and data.RealPosition and data.RealPosition ~= Vector3.new()) 
                       and data.RealPosition 
                       or  ballModel.Position

            -- Detecta teleporte/reset da bola
            if lastBallPos then
                local jump = (bp - lastBallPos).Magnitude
                if jump > Config.ballResetThresh then
                    ballProcessed    = true
                    lastProcessReset = now
                    ballResetAt      = now
                    vel              = Vector3.zero
                    lastBP, lastBT   = nil, nil
                    lastBallPos      = bp
                    continue
                end
            end
            lastBallPos = bp

            if (now - ballResetAt) < Config.ballResetLockout then continue end

            -- Clash detection usando TargetPlayerID nativo
            local currentTarget = data and data.TargetPlayerID
            if currentTarget and currentTarget > 0 then
                updateClashDetection(currentTarget, bp, hrp)
            end

            -- Velocidade: syncData.Speed é a verdade do servidor
            local spd = (data and data.Speed and data.Speed > 0) and data.Speed or nil

            if spd then
                -- Usa velocidade do servidor diretamente
                -- vel como vetor: estimamos direção pela posição
                if lastBP and lastBT then
                    local dtt = now - lastBT
                    if dtt > 0 then
                        local dir = (bp - lastBP)
                        if dir.Magnitude > 0.001 then
                            vel = dir.Unit * spd
                        end
                    end
                end
                lastBT, lastBP = now, bp
            elseif not lastBT then
                lastBT, lastBP = now, bp
            else
                local dtt = now - lastBT
                if dtt > 0 then
                    local raw = (bp - lastBP) / dtt
                    local a   = dt / (Config.velSmooth + dt)
                    vel       = vel + (raw - vel) * a
                    lastBT, lastBP = now, bp
                end
            end

            local speed  = spd or vel.Magnitude
            local hrpPos = hrp.Position
            local d      = (bp - hrpPos).Magnitude
            local app    = vel.Magnitude > 0.1 and vel:Dot(hrpPos - bp) > 0
            local tgt    = isTargetMe()
            local tImp   = speed > 1 and (d / speed) or 1000000
            local ping   = getPingCompensation()

            -- Grace mode: bola em modo "perseguição" → ativa parry mais cedo
            local graceBonus = (data and data.Grace) and 5 or 0

            -- Raio de ativação baseado no KillDistance real + velocidade + ping
            local activationDist = KILL_DIST + graceBonus + (speed * (Config.distanceMultiplier + ping * 0.5))

            local can = tgt and app and speed > 5
                and d <= activationDist
                and tImp <= (Config.maxImpactTime + ping)

            if can and not ballProcessed then
                sendParry()
                ballProcessed    = true
                lastProcessReset = now
                setState("normal")
            end
        end
    end)

    ch.AncestryChanged:Connect(function(_, p)
        if not p then
            running = false
            setSpam(false)
            stopClash()
            ballProcessed = false
            ballLeftMe    = false
            lastBallPos   = nil
            updateGUI()
        end
    end)

    getgenv().__na_aex_conn = { Disconnect = function() running = false end }
end

