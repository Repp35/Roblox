local function switchToTab(n)
    if n == currentTab then return end
    currentTab = n

    if n == 2 then
        -- esconde Tab1
        Body.Visible = false
        -- mostra Tab2 com animacao nos elementos
        CalibCard.BackgroundTransparency = 1
