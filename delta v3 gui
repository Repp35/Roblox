local function saveConfig()
    pcall(function()
        local data = {
            autoParryOn = getgenv().__deltaV3_autoParryOn,
            autoClashOn = getgenv().__deltaV3_autoClashOn,
            auraOn      = getgenv().__deltaV3_auraOn,
            cpsIndex    = selectedCps,
            keyIndex    = selectedKey,
            keyMode     = getgenv().__deltaV3_spamKeyMode or "hold",
            calibFps    = getgenv().__deltaV3_calibFps or "",
            calibPing   = getgenv().__deltaV3_calibPing or "",
        }
        writefile(SAVE_FILE, HttpService:JSONEncode(data))
    end)
end

local savedConfig = {}
