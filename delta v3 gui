-- ============================================================
-- TROCA DE ABAS [7] fix: CalibCard e allCards ficam visíveis corretamente
-- ============================================================
local currentTab  = 1
local tabAnimLock = false

local function switchToTab(n)
    if n == currentTab or tabAnimLock then return end
    tabAnimLock = true

    local fadeOut = n == 2 and Body or Tab2
    local fadeIn  = n == 2 and Tab2 or Body

    -- Atualiza tamanho do Tab2
    if n == 2 then
        local h = Body.AbsoluteSize.Y
        if h > 10 then
            tab2BodyH = h
            Tab2.Size = UDim2.new(1, 0, 0, h)
        end
    end

    -- Reseta transparencias dos destinos
    if n == 2 then
        CalibCard.BackgroundTransparency = 1
    else
        for _, card in ipairs(allCards) do
            card.BackgroundTransparency = 1
        end
    end

    fadeOut.Position = UDim2.new(0, 0, 0, HEADER_H)
    tw(fadeOut, 0.18, {
        Position = UDim2.new(0, 0, 0, HEADER_H + 10),
    }, Enum.EasingStyle.Quad, Enum.EasingDirection.In):Play()

    task.delay(0.18, function()
        fadeOut.Visible  = false
        fadeOut.Position = UDim2.new(0, 0, 0, HEADER_H)

        if n == 2 then
            MainFrame.AutomaticSize = Enum.AutomaticSize.None
            MainFrame.Size = UDim2.new(0, WIDE, 0, HEADER_H + tab2BodyH)
        end

        fadeIn.Position = UDim2.new(0, 0, 0, HEADER_H + 10)
        fadeIn.Visible  = true

        -- [7] garante que os filhos aparecem
        if n == 2 then
            CalibCard.Visible = true
        end

        local tIn = tw(fadeIn, 0.26, {
            Position = UDim2.new(0, 0, 0, HEADER_H),
        }, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        tIn:Play()

        if n == 1 then
            MainFrame.AutomaticSize = Enum.AutomaticSize.Y
            for i, card in ipairs(allCards) do
                task.delay((i-1)*0.04, function()
                    tw(card, 0.26, {BackgroundTransparency=0.35}, Enum.EasingStyle.Back):Play()
                end)
            end
        else
            task.delay(0.05, function()
                tw(CalibCard, 0.26, {BackgroundTransparency=0.35}, Enum.EasingStyle.Back):Play()
            end)
        end

        tIn.Completed:Connect(function()
            currentTab  = n
            tabAnimLock = false
        end)
    end)
end

NavBtn.Activated:Connect(function() switchToTab(2) end)
BackBtn.Activated:Connect(function() switchToTab(1) end)

-- ============================================================
-- DRAG [4] Hitbox so no header e nas bordas (nao na area central)
-- ============================================================
local dragging, dragStart, frameStart = false, nil, nil

local function startDrag(input)
    dragging   = true
    dragStart  = input.Position
    frameStart = MainFrame.Position
    input.Changed:Connect(function()
        if input.UserInputState == Enum.UserInputState.End then dragging = false end
    end)
end

local DRAG_TYPES = {
    [Enum.UserInputType.MouseButton1] = true,
    [Enum.UserInputType.Touch]        = true,
}

-- Header e bordas laterais/inferior (nao a area do body)
Header.InputBegan:Connect(function(i)
    if DRAG_TYPES[i.UserInputType] and i.Position.X < MainFrame.AbsolutePosition.X + MainFrame.AbsoluteSize.X - 50 then
        startDrag(i)
    end
end)

-- Bordas invisíveis de ~16px nas laterais e base [4]
local function makeDragEdge(xScale, xOff, yScale, yOff, wOff, hOff)
    local E = Instance.new("Frame")
    E.BackgroundTransparency = 1
    E.BorderSizePixel        = 0
    E.Size                   = UDim2.new(xScale, wOff, yScale, hOff)
    E.Position               = UDim2.new(0, xOff, 0, yOff)
    E.Parent                 = MainFrame
    E.ZIndex                 = 2
    E.InputBegan:Connect(function(i)
        if DRAG_TYPES[i.UserInputType] then startDrag(i) end
    end)
    return E
end
-- Esquerda, direita, baixo
makeDragEdge(0, 0,    1, 0, 14,   0)
local edgeRight = makeDragEdge(0, 0, 1, 0, 14, 0)
edgeRight.Position = UDim2.new(1, -14, 0, 0)
local edgeBottom = makeDragEdge(1, 0, 0, 0, 0, 12)
edgeBottom.Position = UDim2.new(0, 0, 1, -12)

CollapseBtn.InputBegan:Connect(function() dragging = false end)

UserInputService.InputChanged:Connect(function(input)
    if not dragging then return end
    if input.UserInputType == Enum.UserInputType.MouseMovement
    or input.UserInputType == Enum.UserInputType.Touch then
        local d = input.Position - dragStart
        MainFrame.Position = UDim2.new(
            frameStart.X.Scale, frameStart.X.Offset + d.X,
            frameStart.Y.Scale, frameStart.Y.Offset + d.Y
        )
    end
end)

-- ============================================================
-- COLLAPSE [12] protecao pra nao sair da tela ao minimizar/expandir
-- ============================================================
local isOpen      = true
local lastToggleT = 0
local COOLDOWN    = 0.55

local function clampToScreen()
    local vp     = workspace.CurrentCamera.ViewportSize
    local ap     = MainFrame.AbsolutePosition
    local as     = MainFrame.AbsoluteSize
    local nx     = math.clamp(ap.X, 0, math.max(0, vp.X - as.X))
    local ny     = math.clamp(ap.Y, 0, math.max(0, vp.Y - as.Y))
    if math.abs(nx - ap.X) > 0.5 or math.abs(ny - ap.Y) > 0.5 then
        MainFrame.Position = UDim2.new(0, nx, 0, ny)
    end
end

local function animateHamburger(closing)
    if closing then
        tw(Line1, 0.25, {Position=UDim2.new(0.5,-8,0.5,-1), Rotation= 45}, Enum.EasingStyle.Back):Play()
        tw(Line2, 0.12, {BackgroundTransparency=1}):Play()
        tw(Line3, 0.25, {Position=UDim2.new(0.5,-8,0.5,-1), Rotation=-45}, Enum.EasingStyle.Back):Play()
    else
        tw(Line1, 0.25, {Position=UDim2.new(0.5,-8,0.5,-5), Rotation=0}, Enum.EasingStyle.Back):Play()
        tw(Line2, 0.20, {BackgroundTransparency=0.1}):Play()
        tw(Line3, 0.25, {Position=UDim2.new(0.5,-8,0.5, 3), Rotation=0}, Enum.EasingStyle.Back):Play()
    end
end

local function doCollapse()
    saveConfig()
    animateHamburger(true)
    local cards = currentTab == 1 and allCards or {CalibCard}
    for i, card in ipairs(cards) do
        task.delay((i-1)*0.03, function()
            tw(card, 0.13, {BackgroundTransparency=1}):Play()
        end)
    end
    task.delay(0.15, function()
        Body.Visible = false
        Tab2.Visible = false
        local currentH = MainFrame.AbsoluteSize.Y
        MainFrame.AutomaticSize = Enum.AutomaticSize.None
        MainFrame.Size = UDim2.new(0, WIDE, 0, currentH)
        tw(MainFrame, 0.40, {Size=UDim2.new(0, MINI, 0, HEADER_H)}, Enum.EasingStyle.Quint, Enum.EasingDirection.InOut):Play()
        task.delay(0.40, function()
            -- [12] Clamp pra nao ficar fora da tela
            clampToScreen()
            saveConfig()
        end)
    end)
end

local function doExpand()
    animateHamburger(false)
    tw(MainFrame, 0.42, {Size=UDim2.new(0, WIDE, 0, HEADER_H)}, Enum.EasingStyle.Back, Enum.EasingDirection.Out):Play()
    task.delay(0.20, function()
        tw(MainFrame, 0.22, {BackgroundTransparency=0.2}):Play()
        if currentTab == 1 then
            for _, card in ipairs(allCards) do card.BackgroundTransparency = 1 end
            Body.Visible = true
            task.delay(0.10, function() MainFrame.AutomaticSize = Enum.AutomaticSize.Y end)
            for i, card in ipairs(allCards) do
                task.delay((i-1)*0.05, function()
                    tw(card, 0.30, {BackgroundTransparency=0.35}, Enum.EasingStyle.Back):Play()
                end)
            end
        else
            -- [7] Tab2 expand fix: garante que CalibCard aparece
            CalibCard.BackgroundTransparency = 1
            CalibCard.Visible = true
            Tab2.Visible = true
            MainFrame.AutomaticSize = Enum.AutomaticSize.None
            task.delay(0.10, function()
                local h = tab2BodyH > 10 and tab2BodyH or 300
                Tab2.Size = UDim2.new(1, 0, 0, h)
                MainFrame.Size = UDim2.new(0, WIDE, 0, HEADER_H + h)
            end)
            task.delay(0.12, function()
                tw(CalibCard, 0.30, {BackgroundTransparency=0.35}, Enum.EasingStyle.Back):Play()
            end)
        end
    end)
end

local function toggleCollapse()
    local now = os.clock()
    if now - lastToggleT < COOLDOWN then return end
    lastToggleT = now
    isOpen = not isOpen
    if isOpen then doExpand() else doCollapse() end
end

CollapseBtn.Activated:Connect(toggleCollapse)
CollapseBtn.MouseEnter:Connect(function() tw(CollapseBtn, 0.12, {BackgroundColor3=Color3.fromRGB(50,50,88)}):Play() end)
CollapseBtn.MouseLeave:Connect(function() tw(CollapseBtn, 0.12, {BackgroundColor3=Color3.fromRGB(30,30,55)}):Play() end)

