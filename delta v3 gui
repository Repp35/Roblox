local function getTab2Height()
    return CalibCard.AbsoluteSize.Y + 64
end

-- ============================================================
-- TROCA DE ABAS
-- ============================================================
local currentTab  = 1
local tabAnimLock = false

local function switchToTab(n)
    if n == currentTab or tabAnimLock then return end
    tabAnimLock = true

    if n == 2 then
        -- Garante que Tab2 tem o tamanho correto antes de animar
        syncTab2Position()
        local h = math.max(getTab2Height(), 160)
        Tab2.Size = UDim2.new(0, WIDE, 0, h)

        -- Esconde Body com slide
        tw(Body, 0.18, {
            Position = UDim2.new(0, 0, 0, HEADER_H + 8),
        }, Enum.EasingStyle.Quad, Enum.EasingDirection.In):Play()

        task.delay(0.18, function()
            Body.Visible = false
            Body.Position = UDim2.new(0, 0, 0, HEADER_H)
            MainFrame.AutomaticSize = Enum.AutomaticSize.None
            MainFrame.Size = UDim2.new(0, WIDE, 0, HEADER_H + h)

            -- Tab2 entra
            CalibCard.BackgroundTransparency = 1
            Tab2.Visible = true
            syncTab2Position()

            tw(CalibCard, 0.28, {BackgroundTransparency = 0.35}, Enum.EasingStyle.Back):Play()

            task.delay(0.28, function()
                currentTab  = 2
                tabAnimLock = false
            end)
        end)
    else
        -- Tab2 sai
        tw(CalibCard, 0.15, {BackgroundTransparency = 1}):Play()

        task.delay(0.15, function()
            Tab2.Visible = false

            -- Body volta
            MainFrame.AutomaticSize = Enum.AutomaticSize.Y
            for _, card in ipairs(allCards) do
                card.BackgroundTransparency = 1
            end
            Body.Visible = true

            for i, card in ipairs(allCards) do
                task.delay((i-1)*0.04, function()
                    tw(card, 0.28, {BackgroundTransparency=0.35}, Enum.EasingStyle.Back):Play()
                end)
            end

            task.delay(0.28, function()
                currentTab  = 1
                tabAnimLock = false
            end)
        end)
    end
end

NavBtn.Activated:Connect(function() switchToTab(2) end)
BackBtn.Activated:Connect(function() switchToTab(1) end)

-- ============================================================
-- DRAG
-- ============================================================
local dragging, dragStart, frameStart = false, nil, nil

local function startDrag(input)
    dragging   = true
    dragStart  = input.Position
    frameStart = MainFrame.Position
    input.Changed:Connect(function()
        if input.UserInputState == Enum.UserInputState.End then dragging = false end
    end)
end

local DRAG_TYPES = {
    [Enum.UserInputType.MouseButton1] = true,
    [Enum.UserInputType.Touch]        = true,
}

Header.InputBegan:Connect(function(i)
    if DRAG_TYPES[i.UserInputType] then
        -- Nao inicia drag no botao de colapso
        local ax = MainFrame.AbsolutePosition.X + MainFrame.AbsoluteSize.X - 44
        if i.Position.X < ax then
            startDrag(i)
        end
    end
end)

local function makeDragEdge(pos, size)
    local E = Instance.new("Frame")
    E.BackgroundTransparency = 1
    E.BorderSizePixel        = 0
    E.Size                   = size
    E.Position               = pos
    E.Parent                 = MainFrame
    E.ZIndex                 = 2
    E.InputBegan:Connect(function(i)
        if DRAG_TYPES[i.UserInputType] then startDrag(i) end
    end)
    return E
end
makeDragEdge(UDim2.new(0, 0, 0, HEADER_H),    UDim2.new(0, 12, 1, -HEADER_H))
makeDragEdge(UDim2.new(1, -12, 0, HEADER_H),  UDim2.new(0, 12, 1, -HEADER_H))
