local function selectCps(idx)
    selectedCps = idx
    local all    = getAllCps()
    local chosen = all[idx] or all[7]
    getgenv().__deltaV3_spamInterval    = 1 / chosen.v
    getgenv().__deltaV3_spamIntervalRaw = 1 / chosen.v

    for i, d in ipairs(cpsMain) do
        local s = (i == idx)
        tw(cpsBtns[i], 0.16, {
            BackgroundColor3       = s and Color3.fromRGB(60,100,200) or (d.warn and Color3.fromRGB(150,40,15) or Color3.fromRGB(28,28,48)),
            BackgroundTransparency = s and 0.3 or (d.warn and 0.45 or 0.15),
        }):Play()
        cpsBtns[i].TextColor3 = s and Color3.fromRGB(170,210,255) or (d.warn and Color3.fromRGB(255,120,80) or Color3.fromRGB(105,105,135))
        cpsBtns[i].Text = tostring(d.v) .. (s and "★" or (d.warn and "⚠" or ""))
    end
    for i, d in ipairs(cpsExtra) do
        local gi = #cpsMain + i
        local s  = (gi == idx)
        tw(cpsExtraBtns[i], 0.16, {
            BackgroundColor3       = s and Color3.fromRGB(60,100,200) or Color3.fromRGB(150,40,15),
            BackgroundTransparency = s and 0.3 or 0.45,
        }):Play()
        cpsExtraBtns[i].TextColor3 = s and Color3.fromRGB(170,210,255) or Color3.fromRGB(255,120,80)
        cpsExtraBtns[i].Text = tostring(d.v) .. (s and "★" or "⚠")
    end
    CpsValue.Text = tostring(chosen.v) .. " /s"
    tw(CpsValue, 0.14, {BackgroundColor3 = chosen.warn and Color3.fromRGB(150,50,15) or Color3.fromRGB(50,90,200)}):Play()
    saveConfig()
end

