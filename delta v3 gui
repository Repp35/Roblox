local SAVE_FILE   = "delta_v3_config.json"
local selectedCps = 7
local selectedKey = 1

local function saveConfig()
    pcall(function()
        local guiX, guiY
        pcall(function()
            local ap = MainFrame.AbsolutePosition
            guiX = math.round(ap.X)
            guiY = math.round(ap.Y)
        end)
        local spamGuiPos = getgenv().__deltaV3_savedSpamGuiPos or {}
        local data = {
            autoParryOn    = getgenv().__deltaV3_autoParryOn,
            autoClashOn    = getgenv().__deltaV3_autoClashOn,
            auraOn         = getgenv().__deltaV3_auraOn,
            manualSpamGui  = getgenv().__deltaV3_manualSpamGuiOn or false,
            cpsIndex       = selectedCps,
            keyIndex       = selectedKey,
            keyMode        = getgenv().__deltaV3_spamKeyMode or "hold",
            calibFps       = getgenv().__deltaV3_calibFps  or "",
            calibPing      = getgenv().__deltaV3_calibPing or "",
            calibApplied   = getgenv().__deltaV3_calibrated or false,
            mainGuiX       = guiX,
            mainGuiY       = guiY,
            spamGuiX       = spamGuiPos.x,
            spamGuiY       = spamGuiPos.y,
        }
        writefile(SAVE_FILE, HttpService:JSONEncode(data))
    end)
end

local savedConfig = {}
pcall(function()
    if isfile(SAVE_FILE) then
        savedConfig = HttpService:JSONDecode(readfile(SAVE_FILE))
    end
end)

local function sv(key, default)
    local v = savedConfig[key]
    return v ~= nil and v or default
end

