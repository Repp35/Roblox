-- Helper pra criar campo de input
local function makeInputField(parent, label, xPos, placeholder, savedVal)
    local container = Instance.new("Frame")
    container.Size                   = UDim2.new(0, (WIDE - 60) / 2, 0, 64)
    container.Position               = UDim2.new(0, xPos, 0, 56)
    container.BackgroundTransparency = 1
    container.Parent                 = parent

    -- Label acima
    local lbl = Instance.new("TextLabel")
    lbl.Size                   = UDim2.new(1, 0, 0, 16)
    lbl.Position               = UDim2.new(0, 0, 0, 0)
    lbl.BackgroundTransparency = 1
    lbl.Text                   = label
    lbl.TextColor3             = Color3.fromRGB(150, 170, 220)
    lbl.TextSize               = 10
    lbl.Font                   = Enum.Font.GothamBold
    lbl.TextXAlignment         = Enum.TextXAlignment.Left
    lbl.Parent                 = container

    -- Caixa de input
    local box = Instance.new("Frame")
    box.Size                   = UDim2.new(1, 0, 0, 38)
    box.Position               = UDim2.new(0, 0, 0, 18)
    box.BackgroundColor3       = Color3.fromRGB(12, 12, 28)
    box.BackgroundTransparency = 0.1
    box.BorderSizePixel        = 0
    box.Parent                 = container
    corner(box, 10)

    local boxStroke = stroke(box, Color3.fromRGB(55, 75, 160), 1.2)

    local tb = Instance.new("TextBox")
    tb.Size                   = UDim2.new(1, -16, 1, 0)
    tb.Position               = UDim2.new(0, 8, 0, 0)
    tb.BackgroundTransparency = 1
    tb.Text                   = savedVal or ""
    tb.PlaceholderText        = placeholder
    tb.PlaceholderColor3      = Color3.fromRGB(55, 60, 100)
    tb.TextColor3             = Color3.fromRGB(200, 215, 255)
    tb.TextSize               = 14
    tb.Font                   = Enum.Font.GothamBold
    tb.TextXAlignment         = Enum.TextXAlignment.Center
    tb.ClearTextOnFocus       = false
    tb.Parent                 = box

    -- só números
    tb.Changed:Connect(function(prop)
        if prop == "Text" then
            local clean = tb.Text:gsub("[^%d]", "")
            if clean ~= tb.Text then
                tb.Text = clean
            end
        end
    end)

    -- animação de foco
    tb.Focused:Connect(function()
        tw(box, 0.18, {BackgroundColor3 = Color3.fromRGB(20, 20, 50)}, Enum.EasingStyle.Quad):Play()
        tw(boxStroke, 0.18, {Color = Color3.fromRGB(100, 150, 255), Thickness = 1.8}):Play()
        tw(lbl, 0.18, {TextColor3 = Color3.fromRGB(200, 220, 255)}):Play()
    end)
    tb.FocusLost:Connect(function()
        tw(box, 0.18, {BackgroundColor3 = Color3.fromRGB(12, 12, 28)}):Play()
        tw(boxStroke, 0.18, {Color = Color3.fromRGB(55, 75, 160), Thickness = 1.2}):Play()
        tw(lbl, 0.18, {TextColor3 = Color3.fromRGB(150, 170, 220)}):Play()
    end)

    return tb, lbl, boxStroke
end

