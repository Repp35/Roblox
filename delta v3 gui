    local tb = Instance.new("TextBox")
    tb.Size                   = UDim2.new(1, -12, 1, 0)
    tb.Position               = UDim2.new(0, 6, 0, 0)
    tb.BackgroundTransparency = 1
    tb.Text                   = savedVal or ""
    tb.PlaceholderText        = placeholder
    tb.PlaceholderColor3      = Color3.fromRGB(50, 58, 100)
    tb.TextColor3             = Color3.fromRGB(190, 210, 255)
    tb.TextSize               = 14
    tb.Font                   = Enum.Font.GothamBold
    tb.TextXAlignment         = Enum.TextXAlignment.Center
    tb.ClearTextOnFocus       = false
    tb.Parent                 = box

    -- apenas numeros
    tb.Changed:Connect(function(p)
        if p == "Text" then
            local clean = tb.Text:gsub("[^%d]", "")
            if clean ~= tb.Text then tb.Text = clean end
        end
    end)

    tb.Focused:Connect(function()
        tw(box, 0.14, {BackgroundColor3 = Color3.fromRGB(16, 16, 38)}):Play()
        tw(bs,  0.14, {Color = Color3.fromRGB(85, 128, 255), Thickness = 1.4}):Play()
