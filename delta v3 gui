CollapseBtn.InputBegan:Connect(function() dragging = false end)

UserInputService.InputChanged:Connect(function(input)
    if not dragging then return end
    if input.UserInputType == Enum.UserInputType.MouseMovement
    or input.UserInputType == Enum.UserInputType.Touch then
        local d = input.Position - dragStart
        MainFrame.Position = UDim2.new(
            frameStart.X.Scale, frameStart.X.Offset + d.X,
            frameStart.Y.Scale, frameStart.Y.Offset + d.Y
        )
        -- Atualiza Tab2 junto se estiver visivel
        if currentTab == 2 then
            syncTab2Position()
        end
    end
end)

-- ============================================================
-- COLLAPSE
-- ============================================================
local isOpen      = true
local lastToggleT = 0
local COOLDOWN    = 0.55

-- [FIX] clampToScreen com animacao suave (tween, nao teleporte)
local function clampToScreen(animate)
    local vp = workspace.CurrentCamera.ViewportSize
    local ap = MainFrame.AbsolutePosition
    local as = MainFrame.AbsoluteSize
    local nx = math.clamp(ap.X, 0, math.max(0, vp.X - as.X))
    local ny = math.clamp(ap.Y, 0, math.max(0, vp.Y - as.Y))
    if math.abs(nx - ap.X) > 0.5 or math.abs(ny - ap.Y) > 0.5 then
        if animate then
            tw(MainFrame, 0.35, {Position = UDim2.new(0, nx, 0, ny)}, Enum.EasingStyle.Back, Enum.EasingDirection.Out):Play()
        else
            MainFrame.Position = UDim2.new(0, nx, 0, ny)
        end
        saveConfig()
    end
end

local function animateHamburger(closing)
    if closing then
        tw(Line1, 0.25, {Position=UDim2.new(0.5,-7,0.5,-1), Rotation= 45}, Enum.EasingStyle.Back):Play()
        tw(Line2, 0.12, {BackgroundTransparency=1}):Play()
        tw(Line3, 0.25, {Position=UDim2.new(0.5,-7,0.5,-1), Rotation=-45}, Enum.EasingStyle.Back):Play()
    else
        tw(Line1, 0.25, {Position=UDim2.new(0.5,-7,0.5,-5), Rotation=0}, Enum.EasingStyle.Back):Play()
        tw(Line2, 0.20, {BackgroundTransparency=0.1}):Play()
        tw(Line3, 0.25, {Position=UDim2.new(0.5,-7,0.5, 3), Rotation=0}, Enum.EasingStyle.Back):Play()
    end
end

local function doCollapse()
    saveConfig()
    animateHamburger(true)

    -- Esconde tab ativa
    if currentTab == 2 then
        tw(CalibCard, 0.13, {BackgroundTransparency=1}):Play()
        task.delay(0.14, function() Tab2.Visible = false end)
    else
        for i, card in ipairs(allCards) do
            task.delay((i-1)*0.025, function()
                tw(card, 0.12, {BackgroundTransparency=1}):Play()
            end)
        end
    end

    task.delay(0.14, function()
        Body.Visible = false
        Tab2.Visible = false
        local currentH = MainFrame.AbsoluteSize.Y
        MainFrame.AutomaticSize = Enum.AutomaticSize.None
        MainFrame.Size = UDim2.new(0, WIDE, 0, currentH)
        tw(MainFrame, 0.38, {Size=UDim2.new(0, MINI, 0, HEADER_H)}, Enum.EasingStyle.Quint, Enum.EasingDirection.InOut):Play()
        task.delay(0.40, function()
            -- [FIX] clamp com animacao suave ao colapsar
            clampToScreen(true)
            saveConfig()
        end)
    end)
end

local function doExpand()
    animateHamburger(false)
    tw(MainFrame, 0.40, {Size=UDim2.new(0, WIDE, 0, HEADER_H)}, Enum.EasingStyle.Back, Enum.EasingDirection.Out):Play()

    task.delay(0.18, function()
        tw(MainFrame, 0.22, {BackgroundTransparency=0.2}):Play()

        if currentTab == 1 then
            for _, card in ipairs(allCards) do card.BackgroundTransparency = 1 end
            Body.Visible = true
            task.delay(0.08, function() MainFrame.AutomaticSize = Enum.AutomaticSize.Y end)
            for i, card in ipairs(allCards) do
                task.delay((i-1)*0.04, function()
                    tw(card, 0.28, {BackgroundTransparency=0.35}, Enum.EasingStyle.Back):Play()
                end)
            end
        else
            -- [FIX] Tab2 no ScreenGui, posiciona corretamente ao expandir
            task.delay(0.12, function()
                local h = math.max(getTab2Height(), 160)
                Tab2.Size = UDim2.new(0, WIDE, 0, h)
                MainFrame.AutomaticSize = Enum.AutomaticSize.None
                MainFrame.Size = UDim2.new(0, WIDE, 0, HEADER_H + h)
                syncTab2Position()
                CalibCard.BackgroundTransparency = 1
                Tab2.Visible = true
                tw(CalibCard, 0.28, {BackgroundTransparency=0.35}, Enum.EasingStyle.Back):Play()
            end)
        end
    end)
end

local function toggleCollapse()
    local now = os.clock()
    if now - lastToggleT < COOLDOWN then return end
    lastToggleT = now
    isOpen = not isOpen
    if isOpen then doExpand() else doCollapse() end
end

