-- ============================================================
-- SISTEMA DE ABAS — SLIDE ANIMATION
-- ============================================================
local currentTab  = 1
local tabAnimLock = false

local function switchTab(toTab)
    if tabAnimLock or toTab == currentTab then return end
    tabAnimLock = true

    local goRight = toTab > currentTab

    -- prepara a tab destino
    local dest = toTab == 1 and Tab1 or Tab2
    local orig = toTab == 1 and Tab2 or Tab1

    dest.Position = UDim2.new(goRight and 1 or -1, 0, 0, 0)
    dest.Visible  = true

    -- atualiza dots do header
    tw(dot1, 0.3, {BackgroundColor3 = toTab == 1 and Color3.fromRGB(120,150,255) or Color3.fromRGB(40,40,70)}):Play()
    tw(dot2, 0.3, {BackgroundColor3 = toTab == 2 and Color3.fromRGB(120,150,255) or Color3.fromRGB(40,40,70)}):Play()

    -- slide
    local slideT    = 0.38
    local slideStyle = Enum.EasingStyle.Quint

    tw(orig, slideT, {Position = UDim2.new(goRight and -1 or 1, 0, 0, 0)}, slideStyle, Enum.EasingDirection.InOut):Play()
    local destTween = tw(dest, slideT, {Position = UDim2.new(0, 0, 0, 0)}, slideStyle, Enum.EasingDirection.InOut)
    destTween:Play()
    destTween.Completed:Connect(function()
        orig.Visible  = false
        currentTab    = toTab
        tabAnimLock   = false
    end)
end

NavBtn.Activated:Connect(function() switchTab(2) end)
BackBtn.Activated:Connect(function() switchTab(1) end)

