local keyOptions = {"1","MB1","MB2","F","G","Q","E"}
local keyMap     = {
    ["1"] = Enum.KeyCode.One,
    F = Enum.KeyCode.F, G = Enum.KeyCode.G,
    Q = Enum.KeyCode.Q, E = Enum.KeyCode.E,
}

local keyBtns      = {}
local spamKeyConns = {}

local function clearSpamKeyConns()
    for _, c in ipairs(spamKeyConns) do c:Disconnect() end
    spamKeyConns = {}
end

local function bindSpamKey(label)
    clearSpamKeyConns()
    local function onPress()
        local mode = getgenv().__deltaV3_spamKeyMode or "hold"
        if mode == "toggle" then
            if getgenv().__deltaV3_setSpam then
                getgenv().__deltaV3_setSpam(not (getgenv().__deltaV3_spamActive or false))
            end
        else
            if getgenv().__deltaV3_setSpam then getgenv().__deltaV3_setSpam(true) end
        end
    end
    local function onRelease()
        if (getgenv().__deltaV3_spamKeyMode or "hold") == "hold" then
            if getgenv().__deltaV3_setSpam then getgenv().__deltaV3_setSpam(false) end
        end
    end

    if label == "MB1" or label == "MB2" then
        local uType = label == "MB1"
            and Enum.UserInputType.MouseButton1
            or  Enum.UserInputType.MouseButton2
        table.insert(spamKeyConns, UserInputService.InputBegan:Connect(function(i, g)
            if g then return end
            if i.UserInputType == uType then onPress() end
        end))
        table.insert(spamKeyConns, UserInputService.InputEnded:Connect(function(i)
            if i.UserInputType == uType then onRelease() end
        end))
    else
        local kc = keyMap[label]
        if not kc then return end
        table.insert(spamKeyConns, UserInputService.InputBegan:Connect(function(i, g)
            if g then return end
            if i.KeyCode == kc then onPress() end
        end))
        table.insert(spamKeyConns, UserInputService.InputEnded:Connect(function(i)
            if i.KeyCode == kc then onRelease() end
        end))
    end
end

local function selectKey(idx)
    selectedKey = idx
    for i = 1, #keyOptions do
        local sel = i == idx
        tw(keyBtns[i], 0.16, {
            BackgroundColor3       = sel and Color3.fromRGB(60,100,200) or Color3.fromRGB(28,28,48),
            BackgroundTransparency = sel and 0.3 or 0.15,
        }):Play()
        keyBtns[i].TextColor3 = sel and Color3.fromRGB(170,210,255) or Color3.fromRGB(105,105,135)
    end
    KeyValue.Text = keyOptions[idx]
    bindSpamKey(keyOptions[idx])
    saveConfig()
end

