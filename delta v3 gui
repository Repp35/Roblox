task.spawn(function()
    local t = 0
    while strokeRunning and Stroke.Parent do
        t = t + 0.025
        local r = math.floor(70  + 70  * math.sin(t))
        local g = math.floor(100 + 80  * math.sin(t + 2.1))
        currentStrokeColor = Color3.fromRGB(r, g, 255)

        for i = 1, #syncedStrokes do
            local s = syncedStrokes[i]
            if s and s.Parent then
                s.Color = currentStrokeColor
            end
        end

        -- [FIX] Limpa syncedBtnColors de objetos destruidos enquanto itera
        local alive = {}
        for i = 1, #syncedBtnColors do
            local info = syncedBtnColors[i]
            if info and info.obj and info.obj.Parent then
                info.obj.BackgroundColor3 = Color3.fromRGB(
                    math.floor(info.rBase + info.rAmp * math.sin(t + info.phase)),
                    math.floor(info.gBase + info.gAmp * math.sin(t + info.phase + 2.1)),
                    info.bVal
                )
                alive[#alive + 1] = info
            end
        end
        syncedBtnColors = alive

        task.wait(0.05)
    end
end)

