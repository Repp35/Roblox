    end

    -- salva pra config
    getgenv().__deltaV3_calibFps  = tostring(fpsRaw)
    getgenv().__deltaV3_calibPing = tostring(pingRaw)
    saveConfig()

    -- chama applyCalibration se disponível
    if getgenv().__deltaV3_applyCalibration then
        getgenv().__deltaV3_applyCalibration(fpsRaw, pingRaw)
    end

    -- animação de sucesso
    tw(ApplyBtn, 0.15, {BackgroundColor3 = Color3.fromRGB(30, 160, 80)}):Play()
    ApplyBtn.Text = "✓  APLICADO"
    FeedbackLabel.Text       = "FPS " .. fpsRaw .. " · Ping " .. pingRaw .. "ms — configurado!"
    FeedbackLabel.TextColor3 = Color3.fromRGB(80, 220, 120)
    task.delay(1.8, function()
        tw(ApplyBtn, 0.3, {BackgroundColor3 = Color3.fromRGB(40, 80, 200)}):Play()
        ApplyBtn.Text     = "✦  APLICAR"
        FeedbackLabel.Text = ""
    end)
end)

