local function selectCps(idx)
    selectedCps = idx
    local chosen = allCpsCache[idx] or allCpsCache[7]
    getgenv().__deltaV3_spamInterval    = 1 / chosen.v
    getgenv().__deltaV3_spamIntervalRaw = 1 / chosen.v

    for i, d in ipairs(cpsMain) do
        local s = (i == idx)
        tw(cpsBtns[i], 0.16, {
            BackgroundColor3       = s and Color3.fromRGB(60,100,200) or (d.warn and Color3.fromRGB(150,40,15) or Color3.fromRGB(28,28,48)),
            BackgroundTransparency = s and 0.3 or (d.warn and 0.45 or 0.15),
