    Btn.BorderSizePixel        = 0
    Btn.Font                   = Enum.Font.GothamBold
    Btn.TextSize               = 9
    Btn.LayoutOrder            = i
    Btn.BackgroundColor3       = sel and Color3.fromRGB(60,100,200) or (d.warn and Color3.fromRGB(150,40,15) or Color3.fromRGB(28,28,48))
    Btn.BackgroundTransparency = sel and 0.3 or (d.warn and 0.45 or 0.15)
